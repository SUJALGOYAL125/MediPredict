<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pneumonia Detection | MediPred</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="background-shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
    </div>

    <nav class="navbar glass-panel">
        <div class="nav-brand">
            <i class="fa-solid fa-heart-pulse"></i>
            MediPred
        </div>
        <ul class="nav-links">
            <li><a href="/dashboard"><i class="fa-solid fa-house"></i> Dashboard</a></li>
            <li><a href="/diabetes"><i class="fa-solid fa-droplet"></i> Diabetes</a></li>
            <li><a href="/heart"><i class="fa-solid fa-heart"></i> Heart</a></li>
            <li><a href="/kidney"><i class="fa-solid fa-kidneys"></i> Kidney</a></li>
            <li><a href="/cancer"><i class="fa-solid fa-ribbon"></i> Cancer</a></li>
            <li><a href="/pneumonia" class="active"><i class="fa-solid fa-lungs"></i> Pneumonia</a></li>
            <li><a href="/history"><i class="fa-solid fa-clock-rotate-left"></i> History</a></li>
            <li><a href="/logout" class="btn-logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a></li>
        </ul>
        <div class="hamburger" id="hamburger">
            <i class="fa-solid fa-bars"></i>
        </div>
    </nav>

    <div class="dashboard-container">
        <div class="welcome-section">
            <h1>🫁 Pneumonia <span class="highlight">Detection</span></h1>
            <p>Upload a chest X-ray image to detect pneumonia using Deep Learning CNN</p>
        </div>

        <div class="prediction-layout">
            <div class="prediction-form-card glass-panel">
                <h2><i class="fa-solid fa-image"></i> Upload Chest X-Ray</h2>

                <!-- Image Preview -->
                <div id="imagePreview" style="
                    width: 100%;
                    height: 300px;
                    border: 2px dashed rgba(255,255,255,0.3);
                    border-radius: 15px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    margin-bottom: 1.5rem;
                    overflow: hidden;
                    cursor: pointer;
                ">
                    <div id="placeholder" style="text-align: center; opacity: 0.6;">
                        <i class="fa-solid fa-cloud-arrow-up" style="font-size: 3rem; margin-bottom: 1rem;"></i>
                        <p>Click to upload X-Ray image</p>
                        <p style="font-size: 0.8rem;">JPG, PNG supported</p>
                    </div>
                    <img id="previewImg" src="" style="display:none; width:100%; height:100%; object-fit:contain;" />
                </div>

                <input type="file" id="imageInput" accept="image/*" style="display:none" />

                <button onclick="document.getElementById('imageInput').click()" class="btn-secondary" style="width:100%; justify-content:center; margin-bottom: 1rem;">
                    <i class="fa-solid fa-image"></i> Choose X-Ray Image
                </button>

                <button onclick="predictPneumonia()" class="btn-primary" id="predictBtn" disabled>
                    <i class="fa-solid fa-lungs"></i> Detect Pneumonia
                </button>
            </div>

            <!-- Result -->
            <div id="resultContainer"></div>
        </div>
    </div>

    <script src="/js/main.js"></script>
<script>
    const imageInput = document.getElementById('imageInput');
    const previewImg = document.getElementById('previewImg');
    const placeholder = document.getElementById('placeholder');
    const predictBtn = document.getElementById('predictBtn');

    // Image preview
    imageInput.addEventListener('change', function() {
        const file = this.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                previewImg.src = e.target.result;
                previewImg.style.display = 'block';
                placeholder.style.display = 'none';
                predictBtn.disabled = false;
            }
            reader.readAsDataURL(file);
        }
    });

    // Predict function
    async function predictPneumonia() {
        const file = imageInput.files[0];
        if (!file) return;

        predictBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Analyzing X-Ray...';
        predictBtn.disabled = true;

        const reader = new FileReader();
        reader.onload = async function(e) {
            const base64 = e.target.result.split(',')[1];

            try {
                const response = await fetch('/pneumonia/predict', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ imageBase64: base64 })
                });

                const data = await response.json();

                const resultContainer = document.getElementById('resultContainer');

                if (data.success) {
                    const isPositive = data.is_positive;
                    const colorClass = isPositive ? 'result-positive' : 'result-negative';
                    const icon = isPositive ? 'fa-triangle-exclamation' : 'fa-circle-check';
                    const gradientColor = isPositive
                        ? 'linear-gradient(90deg, #ff416c, #ff4b2b)'
                        : 'linear-gradient(90deg, #11998e, #38ef7d)';

                    resultContainer.innerHTML = `
                        <div class="glass-panel result-card">
                            <h2><i class="fa-solid fa-chart-pie"></i> Prediction Result</h2>
                            <div class="result-content ${colorClass}">
                                <div class="result-icon">
                                    <i class="fa-solid ${icon}"></i>
                                </div>
                                <h3>${data.prediction}</h3>
                                <div class="probability-display">
                                    <span>Pneumonia Probability</span>
                                    <strong>${data.probability}</strong>
                                </div>
                                <div class="progress-bar-bg">
                                    <div class="progress-bar-fill"
                                        style="width: ${data.probability}; background: ${gradientColor}">
                                    </div>
                                </div>
                                <p class="result-note">
                                    <i class="fa-solid fa-circle-info"></i>
                                    This prediction has been saved to your history.
                                </p>
                                <a href="/history" class="btn-secondary">
                                    <i class="fa-solid fa-clock-rotate-left"></i> View History
                                </a>
                            </div>
                        </div>
                    `;
                } else {
                    resultContainer.innerHTML = `
                        <div class="glass-panel result-card">
                            <div class="alert alert-error">
                                <i class="fa-solid fa-circle-exclamation"></i> ${data.error}
                            </div>
                        </div>
                    `;
                }

                resultContainer.scrollIntoView({ behavior: 'smooth' });

            } catch (error) {
                console.error('Error:', error);
            }

            predictBtn.innerHTML = '<i class="fa-solid fa-lungs"></i> Detect Pneumonia';
            predictBtn.disabled = false;
        };
        reader.readAsDataURL(file);
    }
</script>
</body>
</html>