<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Dashboard - MediPredict AI</title>
</head>
<body class="dashboard-body">
    <div class="background-shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
    </div>

    <!-- Navbar -->
    <%- include('partials/navbar') %>

    <!-- Main Content -->
    <div class="dashboard-container">
        <!-- Welcome Section -->
        <div class="welcome-section">
            <h1>Welcome back, <span class="highlight"><%= userName %>!</span> 👋</h1>
            <p>Your personal AI-powered health prediction dashboard.</p>
        </div>

        
        <!-- Stats -->
        <div class="stats-grid">
            <div class="stat-card glass-panel">
                <div class="stat-icon" style="background: linear-gradient(135deg, #4e54c8, #8f94fb);">
                    <i class="fa-solid fa-brain"></i>
                </div>
                <div class="stat-info">
                    <h3>Total Models</h3>
                    <div class="stat-number">4</div>
                    <span>ML & DL Models</span>
                </div>
            </div>

            <div class="stat-card glass-panel">
                <div class="stat-icon" style="background: linear-gradient(135deg, #11998e, #38ef7d);">
                    <i class="fa-solid fa-bullseye"></i>
                </div>
                <div class="stat-info">
                    <h3>Best Accuracy</h3>
                    <div class="stat-number">97%</div>
                    <span>Kidney Disease</span>
                </div>
            </div>

            <div class="stat-card glass-panel">
                <div class="stat-icon" style="background: linear-gradient(135deg, #f953c6, #b91d73);">
                    <i class="fa-solid fa-heart-pulse"></i>
                </div>
                <div class="stat-info">
                    <h3>Diseases</h3>
                    <div class="stat-number">4</div>
                    <span>Covered</span>
                </div>
            </div>

            <div class="stat-card glass-panel">
                <div class="stat-icon" style="background: linear-gradient(135deg, #ff416c, #ff4b2b);">
                    <i class="fa-solid fa-shield-heart"></i>
                </div>
                <div class="stat-info">
                    <h3>Avg Accuracy</h3>
                    <div class="stat-number">90%</div>
                    <span>Across Models</span>
                </div>
            </div>
        </div>

        <!-- Disease Cards -->
        <div class="section-header">
            <h2>🧬 Available Predictions</h2>
            <p>Select a disease to get your AI-powered prediction</p>
        </div>

        <div class="disease-grid">
            <!-- Diabetes Card -->
            <div class="disease-card glass-panel">
                <div class="disease-icon" style="background: linear-gradient(135deg, #f093fb, #f5576c);">
                    <i class="fa-solid fa-syringe"></i>
                </div>
                <div class="disease-info">
                    <h3>Diabetes Prediction</h3>
                    <p>XGBoost ML Model trained on Pima Indians dataset with 76% accuracy.</p>
                    <div class="disease-tags">
                        <span class="tag">XGBoost</span>
                        <span class="tag">76% Accuracy</span>
                        <span class="tag">8 Features</span>
                    </div>
                </div>
                <a href="/diabetes" class="btn-predict-card">
                    Predict Now <i class="fa-solid fa-arrow-right"></i>
                </a>
            </div>

            <!-- heart disease card -->
            <div class="disease-card glass-panel">
                <div class="disease-icon" style="background: linear-gradient(135deg, #ff416c, #ff4b2b);">
                    <i class="fa-solid fa-heart"></i>
                </div>
                <div class="disease-info">
                    <h3>Heart Disease</h3>
                    <p>Predict risk of heart disease using clinical parameters</p>
                    <div class="disease-tags">
                        <span class="tag">Random Forest</span>
                        <span class="tag">85% Accuracy</span>
                        <span class="tag">13 Features</span>
                    </div>
                </div>
                <a href="/heart" class="btn-predict-card">
                    <i class="fa-solid fa-heart-pulse"></i> Predict Now
                </a>
            </div>


            <!-- kidney disease card -->
            <div class="disease-card glass-panel">
                <div class="disease-icon" style="background: linear-gradient(135deg, #8e2de2, #4a00e0);">
                    <i class="fa-solid fa-kidneys"></i>
                </div>
                <div class="disease-info">
                    <h3>Kidney Disease</h3>
                    <p>Detect chronic kidney disease using blood and urine test parameters</p>
                    <div class="disease-tags">
                        <span class="tag">KNN</span>
                        <span class="tag">97.5% Accuracy</span>
                        <span class="tag">26 Features</span>
                    </div>
                </div>
                <a href="/kidney" class="btn-predict-card">
                    <i class="fa-solid fa-kidneys"></i> Predict Now
                </a>
            </div>

            <!-- Breast cancer disease card -->
            <div class="disease-card glass-panel">
                <div class="disease-icon" style="background: linear-gradient(135deg, #f953c6, #b91d73);">
                    <i class="fa-solid fa-ribbon"></i>
                </div>
                <div class="disease-info">
                    <h3>Breast Cancer Disease</h3>
                    <p>Detect breast cancer as malignant or benign using cell nucleus measurements</p>
                    <div class="disease-tags">
                        <span class="tag">SVM</span>
                        <span class="tag">97% Accuracy</span>
                        <span class="tag">30 Features</span>
                    </div>
                </div>
                <a href="/cancer" class="btn-predict-card">
                    <i class="fa-solid fa-ribbon"></i> Predict Now
                </a>
            </div>

            <!-- Pneumonia detection card -->
            <div class="disease-card glass-panel">
                <div class="disease-icon" style="background: linear-gradient(135deg, #4e54c8, #8f94fb);">
                    <i class="fa-solid fa-lungs"></i>
                </div>
                <div class="disease-info">
                    <h3>Pneumonia Detection</h3>
                    <p>Detect pneumonia from chest X-ray images using Deep Learning CNN</p>
                    <div class="disease-tags">
                        <span class="tag">CNN</span>
                        <span class="tag">Deep Learning</span>
                        <span class="tag">84% Accuracy</span>
                    </div>
                </div>
                <a href="/pneumonia" class="btn-predict-card">
                    <i class="fa-solid fa-lungs"></i> Predict Now
                </a>
            </div>
            

            <!-- Coming Soon Cards -->
            <div class="disease-card glass-panel coming-soon">
                <div class="disease-icon" style="background: linear-gradient(135deg, #4facfe, #00f2fe);">
                    <i class="fa-solid fa-lungs"></i>
                </div>
                <div class="disease-info">
                    <h3>Kidney Disease</h3>
                    <p>Early detection of chronic kidney disease using ML.</p>
                    <div class="disease-tags">
                        <span class="tag coming">Coming Soon</span>
                    </div>
                </div>
                <button class="btn-predict-card disabled" disabled>
                    Coming Soon <i class="fa-solid fa-clock"></i>
                </button>
            </div>
        </div>

        <!-- Quick Links -->
        <div class="quick-links glass-panel">
            <h3><i class="fa-solid fa-bolt"></i> Quick Actions</h3>
            <div class="quick-grid">
                <a href="/diabetes" class="quick-btn">
                    <i class="fa-solid fa-syringe"></i>
                    <span>New Prediction</span>
                </a>
                <a href="/history" class="quick-btn">
                    <i class="fa-solid fa-clock-rotate-left"></i>
                    <span>View History</span>
                </a>
                <a href="/logout" class="quick-btn danger">
                    <i class="fa-solid fa-right-from-bracket"></i>
                    <span>Logout</span>
                </a>
            </div>
        </div>
    </div>

    <script src="/js/main.js"></script>
</body>
</html>
