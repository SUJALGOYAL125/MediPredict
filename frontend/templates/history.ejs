<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>History - MediPredict AI</title>
</head>
<body class="dashboard-body">
    <div class="background-shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
    </div>

    <!-- Navbar -->
    <%- include('partials/navbar') %>

    <div class="dashboard-container">
        <div class="welcome-section">
            <h1><i class="fa-solid fa-clock-rotate-left"></i> Prediction History</h1>
            <p>Track your health predictions and monitor improvements over time.</p>
        </div>

        <% if (predictions.length === 0) { %>
            <div class="glass-panel empty-state">
                <i class="fa-solid fa-file-circle-xmark"></i>
                <h3>No predictions yet!</h3>
                <p>Make your first prediction to see your history here.</p>
                <a href="/diabetes" class="btn-primary">
                    <i class="fa-solid fa-syringe"></i> Make First Prediction
                </a>
            </div>
        <% } else { %>
            <div class="history-stats glass-panel">
                <div class="hstat">
                    <h3><%= predictions.length %></h3>
                    <span>Total Predictions</span>
                </div>
                <div class="hstat">
                    <h3><%= predictions.filter(p => p.isDiabetic).length %></h3>
                    <span>Positive Results</span>
                </div>
                <div class="hstat">
                    <h3><%= predictions.filter(p => !p.isDiabetic).length %></h3>
                    <span>Negative Results</span>
                </div>
            </div>

            <div class="history-table glass-panel">
                <h2><i class="fa-solid fa-table"></i> All Predictions</h2>
                <div class="table-responsive">
                    <table>
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Disease</th>
                                <th>Result</th>
                                <th>Probability</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% predictions.forEach((pred, index) => { %>
                            <tr>
                                <td><%= index + 1 %></td>
                                <td>
                                    <span class="disease-badge">
                                        <i class="fa-solid fa-syringe"></i> <%= pred.disease %>
                                    </span>
                                </td>
                                <td>
                                    <span class="result-badge <%= pred.isDiabetic ? 'badge-positive' : 'badge-negative' %>">
                                        <i class="fa-solid <%= pred.isDiabetic ? 'fa-triangle-exclamation' : 'fa-circle-check' %>"></i>
                                        <%= pred.isDiabetic ? 'Positive' : 'Negative' %>
                                    </span>
                                </td>
                                <td><strong><%= pred.probability %></strong></td>
                                <td><%= new Date(pred.date).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %></td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% } %>
    </div>

    <script src="/js/main.js"></script>
</body>
</html>
