<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Heart Disease Prediction | MediPred</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="background-shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
    </div>

    <!-- Navbar -->
    <nav class="navbar glass-panel">
        <div class="nav-brand">
            <i class="fa-solid fa-heart-pulse"></i>
            MediPred
        </div>
        <ul class="nav-links">
            <li><a href="/dashboard"><i class="fa-solid fa-house"></i> Dashboard</a></li>
            <li><a href="/diabetes"><i class="fa-solid fa-droplet"></i> Diabetes</a></li>
            <li><a href="/heart" class="active"><i class="fa-solid fa-heart"></i> Heart</a></li>
            <li><a href="/history"><i class="fa-solid fa-clock-rotate-left"></i> History</a></li>
            <li><a href="/logout" class="btn-logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a></li>
        </ul>
        <div class="hamburger" id="hamburger">
            <i class="fa-solid fa-bars"></i>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="dashboard-container">
        <div class="welcome-section">
            <h1>❤️ Heart Disease <span class="highlight">Prediction</span></h1>
            <p>Enter your health details below to predict heart disease risk</p>
        </div>

        <div class="prediction-layout">
            <!-- Form -->
            <div class="prediction-form-card glass-panel">
                <h2><i class="fa-solid fa-clipboard-list"></i> Enter Health Details</h2>
                <form action="/heart/predict" method="POST">
                    <div class="form-grid">

                        <div class="input-group">
                            <label>Age</label>
                            <input type="number" name="age" placeholder="e.g. 55" required />
                        </div>

                        <div class="input-group">
                            <label>Sex (0=Female, 1=Male)</label>
                            <input type="number" name="sex" placeholder="0 or 1" min="0" max="1" required />
                        </div>

                        <div class="input-group">
                            <label>Chest Pain Type (0-3)</label>
                            <input type="number" name="cp" placeholder="0 to 3" min="0" max="3" required />
                        </div>

                        <div class="input-group">
                            <label>Resting Blood Pressure</label>
                            <input type="number" name="trestbps" placeholder="e.g. 130" required />
                        </div>

                        <div class="input-group">
                            <label>Cholesterol</label>
                            <input type="number" name="chol" placeholder="e.g. 250" required />
                        </div>

                        <div class="input-group">
                            <label>Fasting Blood Sugar (0 or 1)</label>
                            <input type="number" name="fbs" placeholder="0 or 1" min="0" max="1" required />
                        </div>

                        <div class="input-group">
                            <label>Resting ECG (0-2)</label>
                            <input type="number" name="restecg" placeholder="0 to 2" min="0" max="2" required />
                        </div>

                        <div class="input-group">
                            <label>Max Heart Rate</label>
                            <input type="number" name="thalach" placeholder="e.g. 150" required />
                        </div>

                        <div class="input-group">
                            <label>Exercise Induced Angina (0 or 1)</label>
                            <input type="number" name="exang" placeholder="0 or 1" min="0" max="1" required />
                        </div>

                        <div class="input-group">
                            <label>ST Depression (oldpeak)</label>
                            <input type="number" step="0.1" name="oldpeak" placeholder="e.g. 2.3" required />
                        </div>

                        <div class="input-group">
                            <label>Slope (0-2)</label>
                            <input type="number" name="slope" placeholder="0 to 2" min="0" max="2" required />
                        </div>

                        <div class="input-group">
                            <label>Number of Major Vessels (0-3)</label>
                            <input type="number" name="ca" placeholder="0 to 3" min="0" max="3" required />
                        </div>

                        <div class="input-group">
                            <label>Thal (1=Normal, 2=Fixed, 3=Reversible)</label>
                            <input type="number" name="thal" placeholder="1, 2 or 3" min="1" max="3" required />
                        </div>

                    </div>
                    <button type="submit" class="btn-primary">
                        <i class="fa-solid fa-heart-pulse"></i> Predict Heart Disease
                    </button>
                </form>
            </div>

            <!-- Result -->
            <% if (result) { %>
            <div class="result-card glass-panel">
                <h2><i class="fa-solid fa-chart-simple"></i> Prediction Result</h2>

                <% if (result.error) { %>
                <div class="alert alert-error">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                    <%= result.error %>
                </div>

                <% } else { %>
                <div class="result-content <%= result.is_positive ? 'result-positive' : 'result-negative' %>">
                    <div class="result-icon">
                        <% if (result.is_positive) { %>
                            <i class="fa-solid fa-heart-crack"></i>
                        <% } else { %>
                            <i class="fa-solid fa-heart"></i>
                        <% } %>
                    </div>

                    <h3><%= result.prediction %></h3>

                    <div class="probability-display">
                        <span>Risk Probability</span>
                        <strong><%= result.probability %></strong>
                    </div>

                    <div class="progress-bar-bg">
                        <div class="progress-bar-fill"
                            style="width: <%= result.probability %>;
                            background: <%= result.is_positive ? 'linear-gradient(90deg, #ff416c, #ff4b2b)' : 'linear-gradient(90deg, #11998e, #38ef7d)' %>">
                        </div>
                    </div>

                    <p class="result-note">
                        <i class="fa-solid fa-circle-info"></i>
                        This is an AI prediction. Please consult a doctor for proper diagnosis.
                    </p>
                </div>
                <% } %>
            </div>
            <% } %>

        </div>
    </div>

    <script src="/js/main.js"></script>
</body>
</html>